Answer:
class Solution:
    def zigZagArrays(self, n: int, l: int, r: int) -> int:
        MOD = 10**9 + 7
        m = r - l + 1

        if n == 1:
            return m

        up = [0] * m
        down = [0] * m

        # For length 2
        for i in range(m):
            up[i] = i              # previous value is smaller
            down[i] = m - i - 1    # previous value is bigger

        for _ in range(3, n + 1):
            new_up = [0] * m
            new_down = [0] * m

            prefix = 0
            for i in range(m):
                new_up[i] = prefix
                prefix = (prefix + down[i]) % MOD

            suffix = 0
            for i in range(m - 1, -1, -1):
                new_down[i] = suffix
                suffix = (suffix + up[i]) % MOD

            up = new_up
            down = new_down

        return (sum(up) + sum(down)) % MOD



Optimized Solution:

class Solution:
    def zigZagArrays(self, n: int, l: int, r: int) -> int:
        MOD = 10**9 + 7
        m = r - l + 1

        if n == 1:
            return m
        if m == 1:
            return 0
        if n == 2:
            return m * (m - 1) % MOD

        size = 2 * m

        def mat_mul(A, B):
            C = [[0] * size for _ in range(size)]
            for i in range(size):
                for k in range(size):
                    if A[i][k]:
                        for j in range(size):
                            C[i][j] = (C[i][j] + A[i][k] * B[k][j]) % MOD
            return C

        def mat_vec_mul(A, v):
            res = [0] * size
            for i in range(size):
                total = 0
                for j in range(size):
                    total += A[i][j] * v[j]
                res[i] = total % MOD
            return res

        # initial DP for length 2
        vec = [0] * size

        for i in range(m):
            vec[i] = i              # up
            vec[m + i] = m - i - 1  # down

        # transition matrix
        T = [[0] * size for _ in range(size)]

        for i in range(m):
            # new_up[i] = sum(down[j]) for j < i
            for j in range(i):
                T[i][m + j] = 1

            # new_down[i] = sum(up[j]) for j > i
            for j in range(i + 1, m):
                T[m + i][j] = 1

        power = n - 2

        while power:
            if power & 1:
                vec = mat_vec_mul(T, vec)

            T = mat_mul(T, T)
            power //= 2

        return sum(vec) % MOD




Time Complexity: O(n * (r - l + 1))

Explanation:
A valid ZigZag array must alternate direction:

up, down, up, down...

or

down, up, down, up...

Because:

1, 2, 3

has two increasing moves, so it is invalid.

We use DP:

up[i]

means number of arrays ending at value i where the last move was increasing.

down[i]

means number of arrays ending at value i where the last move was decreasing.

For a new increasing move:

new_up[i] = sum of down[j] where j < i

For a new decreasing move:

new_down[i] = sum of up[j] where j > i

Prefix sum helps calculate new_up.

Suffix sum helps calculate new_down.
