from typing import List

class Fenwick:
    def __init__(self, size):
        self.bit = [0] * (size + 1)

    def update(self, index, value):
        while index < len(self.bit):
            self.bit[index] += value
            index += index & -index

    def query(self, index):
        total = 0
        while index > 0:
            total += self.bit[index]
            index -= index & -index
        return total


class Solution:
    def countMajoritySubarrays(self, nums: List[int], target: int) -> int:
        n = len(nums)

        offset = n + 2
        size = 2 * n + 5

        bit = Fenwick(size)

        prefix = 0
        ans = 0

        # empty prefix
        bit.update(prefix + offset, 1)

        for num in nums:
            if num == target:
                prefix += 1
            else:
                prefix -= 1

            # Need previous prefix < current prefix
            ans += bit.query(prefix + offset - 1)

            bit.update(prefix + offset, 1)

        return ans


Time Complexity: O(n logn)

Explanation:
Convert array:

target     -> +1
not target -> -1

Now, in any subarray:

sum > 0

means target appears more than all non-target elements combined.

So target is majority when:

prefix[j] - prefix[i] > 0

That means:

prefix[j] > prefix[i]

So for every current prefix, count how many previous prefix sums are smaller.

Fenwick Tree helps do this fast.
