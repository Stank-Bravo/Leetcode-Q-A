class Solution:
    def totalWaviness(self, num1: int, num2: int) -> int:
        def solve(n):
            if n <= 0:
                return 0
            
            digits = list(map(int, str(n)))
            length = len(digits)
            
            @lru_cache(None)
            def dp(pos, prev2, prev1, cnt_digits, tight):
                if pos == length:
                    return (1, 0)
                
                limit = digits[pos] if tight else 9
                
                total_cnt = 0
                total_wav = 0
                
                for d in range(limit + 1):
                    new_tight = tight and (d == limit)
                    
                    if cnt_digits == 0 and d == 0:
                        child_cnt, child_wav = dp(pos + 1, -1, -1, 0, new_tight)
                        total_cnt += child_cnt
                        total_wav += child_wav
                    else:
                        add = 0
                        
                        if cnt_digits >= 2:
                            if (prev2 < prev1 > d) or (prev2 > prev1 < d):
                                add = 1
                        
                        child_cnt, child_wav = dp(
                            pos + 1,
                            prev1,
                            d,
                            cnt_digits + 1,
                            new_tight
                        )
                        
                        total_cnt += child_cnt
                        total_wav += child_wav + add * child_cnt
                
                return (total_cnt, total_wav)
            
            cnt, wav = dp(0, -1, -1, 0, True)
            return wav
        
        return solve(num2) - solve(num1 - 1)


